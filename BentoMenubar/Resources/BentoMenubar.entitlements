<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Bento Menubar shells out to the `bento` CLI, `tmux`, and Terminal.app.
         We do NOT sandbox so that Process can invoke arbitrary binaries on the
         user's PATH (tmux, claude-code, etc.) and write to ~/.bento/. -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
    <!-- Distribution builds sign with the hardened runtime (notarization
         requires it), which blocks microphone capture unless this is granted.
         Without it, hold-to-talk silently records nothing on other Macs.
         Harmless in dev builds (no hardened runtime → not consulted). -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
</dict>
</plist>
